{% extends 'base.html.twig' %}

{% block title %}Interventions — Runflow{% endblock %}
{% block page_title %}Gestion des interventions{% endblock %}

{% block body %}

{# ── Filtres par statut ── #}
<div class="filter-bar">
    <a href="{{ path('app_admin_intervention_index') }}"
       class="filter-btn {% if statut_actif is null %}active{% endif %}">
        Toutes
    </a>
    {% for statut in statuts %}
    <a href="{{ path('app_admin_intervention_index', {statut: statut.value}) }}"
       class="filter-btn {% if statut_actif == statut.value %}active{% endif %}">
        {{ statut.label() }}
    </a>
    {% endfor %}
</div>

<div class="dashboard-section">
    {% if interventions is empty %}
        <p class="empty-state">Aucune intervention trouvée.</p>
    {% else %}
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Client</th>
                    <th>Description</th>
                    <th>Adresse</th>
                    <th>Date demande</th>
                    <th>Date souhaitée</th>
                    <th>Technicien</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for intervention in interventions %}
                <tr>
                    <td>#{{ intervention.id }}</td>
                    <td>{{ intervention.client.nomComplet }}</td>
                    <td>{{ intervention.description|slice(0, 50) }}{% if intervention.description|length > 50 %}…{% endif %}</td>
                    <td>{{ intervention.adresse }}</td>
                    <td>{{ intervention.dateDemande|date('d/m/Y') }}</td>
                    <td>{{ intervention.dateSouhaitee|date('d/m/Y') }}</td>
                    <td>
                        {% if intervention.technicien %}
                            {{ intervention.technicien.nomComplet }}
                        {% else %}
                            <span class="text-muted">Non assigné</span>
                        {% endif %}
                    </td>
                    <td>
                        <span class="badge badge-{{ intervention.statut.value }}">
                            {{ intervention.statut.label() }}
                        </span>
                    </td>
                    <td>
                        <a href="{{ path('app_admin_intervention_show', {id: intervention.id}) }}"
                           class="btn btn-sm">
                            Voir
                        </a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>

{% endblock %}