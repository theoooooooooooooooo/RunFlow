{% extends 'base.html.twig' %}

{% block title %}Nouveau matériel — Runflow{% endblock %}
{% block page_title %}Ajouter un matériel{% endblock %}

{% block body %}

<div class="dashboard-section" style="max-width: 600px;">
    {{ form_start(form) }}

    <div class="form-group">
        {{ form_label(form.nom) }}
        {{ form_widget(form.nom) }}
        {{ form_errors(form.nom) }}
    </div>

    <div class="form-group">
        {{ form_label(form.description) }}
        {{ form_widget(form.description) }}
        {{ form_errors(form.description) }}
    </div>

    <div class="form-group">
        {{ form_label(form.quantite_stock) }}
        {{ form_widget(form.quantite_stock) }}
        {{ form_errors(form.quantite_stock) }}
    </div>

    <div style="display: flex; gap: 12px; margin-top: 24px;">
        <button type="submit" class="btn btn-primary">Ajouter</button>
        <a href="{{ path('app_admin_materiel_index') }}" class="btn btn-secondary">Annuler</a>
    </div>

    {{ form_end(form) }}
</div>

{% endblock %}