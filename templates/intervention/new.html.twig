{% extends 'base.html.twig' %}

{% block title %}Nouvelle demande — Runflow{% endblock %}
{% block page_title %}Nouvelle demande d'intervention{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('vendor/flatpickr/flatpickr.min.css') }}">
{% endblock %}

{% block body %}

<div class="dashboard-section" style="max-width: 700px;">

    {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

    <div class="form-group">
        {{ form_label(form.description) }}
        {{ form_widget(form.description) }}
        {{ form_errors(form.description) }}
    </div>

    <div class="form-group">
        {{ form_label(form.date_souhaitee) }}
        {{ form_widget(form.date_souhaitee) }}
        {{ form_errors(form.date_souhaitee) }}
        <small class="text-muted">Créneaux disponibles : lundi au vendredi, 8h – 18h</small>
    </div>

    <hr style="margin: 24px 0; border-color: #e5e7eb;">
    <h3 style="margin-bottom: 16px; font-size: 1rem; color: #374151;">Adresse d'intervention</h3>

    <div class="form-group">
        {{ form_label(form.adresse_existante) }}
        {{ form_widget(form.adresse_existante) }}
    </div>

    <div id="nouvelle-adresse-fields">
        <div class="form-row">
            <div class="form-group">
                {{ form_label(form.adresse_rue) }}
                {{ form_widget(form.adresse_rue) }}
                {{ form_errors(form.adresse_rue) }}
            </div>
            <div class="form-group">
                {{ form_label(form.adresse_ville) }}
                {{ form_widget(form.adresse_ville) }}
                {{ form_errors(form.adresse_ville) }}
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                {{ form_label(form.adresse_code_postal) }}
                {{ form_widget(form.adresse_code_postal) }}
                {{ form_errors(form.adresse_code_postal) }}
            </div>
            <div class="form-group">
                {{ form_label(form.adresse_complement) }}
                {{ form_widget(form.adresse_complement) }}
                {{ form_errors(form.adresse_complement) }}
            </div>
        </div>
    </div>

    <div style="display: flex; gap: 12px; margin-top: 24px;">
        <button type="submit" class="btn btn-primary">Envoyer ma demande</button>
        <a href="{{ path('app_client_dashboard') }}" class="btn btn-secondary">Annuler</a>
    </div>

    {{ form_end(form) }}

</div>

{% endblock %}

{% block javascripts %}
<script src="{{ asset('vendor/flatpickr/flatpickr.min.js') }}"></script>
<script src="{{ asset('vendor/flatpickr/fr.js') }}"></script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const input = document.getElementById('date-souhaitee-picker');

        if (input) {
            flatpickr(input, {
                locale: 'fr',
                enableTime: true,
                dateFormat: 'Y-m-d H:i',
                altInput: true,
                altFormat: 'j F Y à H:i',
                minDate: 'today',
                minTime: '08:00',
                maxTime: '18:00',
                disable: [
                    function (date) {
                        // Désactive samedi (6) et dimanche (0)
                        return date.getDay() === 0 || date.getDay() === 6;
                    }
                ],
                time_24hr: true,
            });
        }
    });

    document.addEventListener('DOMContentLoaded', function () {
        const selectAdresse = document.getElementById('select-adresse-existante');
        const nouvelleAdresseFields = document.getElementById('nouvelle-adresse-fields');

        function toggleNouvelleAdresse() {
            if (selectAdresse.value) {
                nouvelleAdresseFields.style.display = 'none';
            } else {
                nouvelleAdresseFields.style.display = 'block';
            }
        }

        if (selectAdresse) {
            toggleNouvelleAdresse();
            selectAdresse.addEventListener('change', toggleNouvelleAdresse);
        }
    });
</script>
{% endblock %}