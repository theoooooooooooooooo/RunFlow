<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Runflow{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body>

    {% if app.user %}
    <aside class="sidebar">
        <div class="logo">RunFlow</div>
        <nav class="menu">

            {% if is_granted('ROLE_CLIENT') %}
                <a href="{{ path('app_client_dashboard') }}">🏠 Dashboard</a>
                <a href="{{ path('app_intervention_client') }}">📋 Mes interventions</a>
                <a href="{{ path('app_intervention_new') }}">➕ Nouvelle demande</a>
            {% endif %}

            {% if is_granted('ROLE_TECHNICIEN') %}
                <a href="{{ path('app_technicien_dashboard') }}">🏠 Dashboard</a>
                <a href="{{ path('app_intervention_technicien') }}">📋 Mes interventions</a>
            {% endif %}

            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_admin_dashboard') }}">🏠 Dashboard</a>
                <a href="{{ path('app_admin_intervention_index') }}">📋 Interventions</a>  {# ← changer ici #}
                <a href="#">👥 Techniciens</a>
                <a href="#">🔧 Matériel</a>
                <a href="#">📦 Stock</a>
                <a href="#">📅 Planning</a>
                <a href="#">👤 Clients</a>
            {% endif %}

            <a href="{{ path('app_logout') }}" class="logout">🚪 Déconnexion</a>
        </nav>
    </aside>
    {% endif %}

    <div class="main">

        <div class="topbar">
            <h1>{% block page_title %}{% endblock %}</h1>
            {% if app.user %}
            <div class="profile">
                {% if is_granted('ROLE_ADMIN') %}
                    {{ app.user.nom }}
                {% else %}
                    {{ app.user.nomComplet }}
                {% endif %}
            </div>
            {% endif %}
        </div>

        {% for message in app.flashes('success') %}
            <div class="flash-success">✓ {{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash-error">✗ {{ message }}</div>
        {% endfor %}

        {% block body %}{% endblock %}
    </div>

    {% block javascripts %}{% endblock %}
</body>
</html>