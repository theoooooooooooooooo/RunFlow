{% extends 'base.html.twig' %}

{% block title %}Connexion — Runflow{% endblock %}
{% block page_title %}Connexion{% endblock %}

{% block body %}

<div class="dashboard-section" style="max-width: 420px; margin: 60px auto;">

    <h2 style="margin-bottom: 20px; text-align: center;">Connexion à Runflow</h2>

    <form method="post">
        {% if error %}
            <div class="flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        {% if app.user %}
            <div class="flash-success">
                Vous êtes déjà connecté en tant que {{ app.user.userIdentifier }},
                <a href="{{ logout_path() }}">se déconnecter</a>
            </div>
        {% endif %}

        <div class="form-group">
            <label for="inputEmail">Adresse e-mail</label>
            <input type="email" value="{{ last_username }}" name="email" id="inputEmail"
                   autocomplete="email" required autofocus>
        </div>

        <div class="form-group">
            <label for="inputPassword">Mot de passe</label>
            <input type="password" name="password" id="inputPassword"
                   autocomplete="current-password" required>
        </div>

        <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

        <div class="form-group" style="flex-direction: row; align-items: center; gap: 8px;">
            <input type="checkbox" name="_remember_me" id="rememberMe" style="width: auto;">
            <label for="rememberMe" style="margin: 0;">Se souvenir de moi</label>
        </div>

        <button class="btn btn-primary" type="submit" style="width: 100%; margin-top: 12px;">
            Se connecter
        </button>
    </form>

    <p style="text-align: center; margin-top: 16px; font-size: .9rem; color: #6b7280;">
        Pas encore de compte ?
        <a href="{{ path('app_register') }}" style="color: #2563eb;">S'inscrire</a>
    </p>

</div>

{% endblock %}