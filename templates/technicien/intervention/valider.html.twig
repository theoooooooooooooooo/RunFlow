{% extends 'base.html.twig' %}

{% block title %}Valider l'intervention #{{ intervention.id }} — Runflow{% endblock %}
{% block page_title %}Valider l'intervention #{{ intervention.id }}{% endblock %}

{% block body %}

<div class="dashboard-section" style="max-width: 700px;">

    <div style="background:#f8fafc; border-radius:10px; padding:16px; margin-bottom:24px; font-size:.9rem;">
        <p><strong>Client :</strong> {{ intervention.client.nomComplet }}</p>
        <p><strong>Adresse :</strong> {{ intervention.adresse }}</p>
        <p><strong>Description :</strong> {{ intervention.description }}</p>
    </div>

    {{ form_start(form) }}

    <div class="form-group">
        {{ form_label(form.contenu) }}
        {{ form_widget(form.contenu) }}
        {{ form_errors(form.contenu) }}
    </div>

    <div style="display: flex; gap: 12px; margin-top: 20px;">
        <button type="submit" class="btn btn-primary">
            ✓ Valider et terminer l'intervention
        </button>
        <a href="{{ path('app_intervention_show', {id: intervention.id}) }}" class="btn btn-secondary">
            Annuler
        </a>
    </div>

    {{ form_end(form) }}

</div>

{% endblock %}